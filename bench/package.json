{
  "name": "shoebench",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "start": "bun --bun run ./cli.tsx",
    "cli": "bun --bun run ./cli.tsx",
    "run": "bun --bun run ./index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "vision": "bun run ./run-vision-benchmark.ts",
    "vision:quick": "bun run ./run-vision-benchmark.ts --quick",
    "vision:all": "bun run ./run-vision-benchmark.ts --shoes=89",
    "vision:budget": "bun run ./run-vision-benchmark.ts --tier=budget",
    "vision:mid": "bun run ./run-vision-benchmark.ts --tier=mid",
    "vision:premium": "bun run ./run-vision-benchmark.ts --tier=premium",
    "vision:free": "bun run ./run-vision-benchmark.ts --tier=free",
    "judge": "bun run ./run-judge-benchmark.ts",
    "export": "bun run ../visualizer/scripts/export-results.ts",
    "all": "bun run vision:all && bun run judge && bun run export",
    "quick": "bun run vision:quick && bun run judge && bun run export",
    "free": "bun run vision:free && bun run judge && bun run export",
    "update-models": "bun run ./scripts/update-vision-models.ts",
    "update-models:dry": "bun run ./scripts/update-vision-models.ts --dry-run"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.7.8",
    "@types/react": "^18.3.5"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.46",
    "@openrouter/ai-sdk-provider": "^1.4.0",
    "ai": "^5.0.107",
    "dotenv": "^17.2.3",
    "ink": "^6.5.1",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "openai": "^6.10.0",
    "p-limit": "^7.2.0",
    "react": "^19.2.1"
  }
}
